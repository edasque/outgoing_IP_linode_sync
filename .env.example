# Pushover Configuration
# Get your User Key from: https://pushover.net/
# Create an app to get the App Token: https://pushover.net/apps/build
PUSHOVER_USER_KEY=your_pushover_user_key_here
PUSHOVER_TOKEN=your_pushover_app_token_here

# Linode API Configuration
# Create a Personal Access Token from: https://cloud.linode.com/profile/tokens
# Make sure it has Domains Read/Write permission
LINODE_API_TOKEN=your_linode_api_token_here

# Domain Configuration
# The domain name you want to update DNS records for
DOMAIN_NAME=example.com

# Optional Database Configuration
# DATABASE_PATH=./ip_history.db

# Optional: Custom IP check service
# IP_CHECK_URL=https://checkip.amazonaws.com/

# Optional: Timezone for cron jobs
# TIMEZONE=America/New_York